{
  "gitVersion": "git version 2.50.1 (Apple Git-155)",
  "LANG": "C",
  "source": "synthetic",
  "command": "git status --porcelain=v2 -b --untracked-files=all --renames",
  "stdoutEncoding": "utf-8",
  "delimiter": "LF",
  "records": [
    "# branch.oid 0123456789abcdef0123456789abcdef01234567",
    "# branch.head main",
    "2 R. N... 100644 100644 100644 0123456789abcdef0123456789abcdef01234567 89abcdef012345670123456789abcdef01234567 R100 src/new-name.ts\tsrc/old-name.ts"
  ],
  "notes": ["Line-delimited rename stores new and old paths in one tab-separated path tail."]
}
