{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-code.local/schema/harness-observer.schema.json",
  "title": "HarnessObserverEvent",
  "oneOf": [
    {
      "$ref": "#/$defs/tabBadgeEvent"
    },
    {
      "$ref": "#/$defs/toolCallEvent"
    },
    {
      "$ref": "#/$defs/sessionHistoryEvent"
    }
  ],
  "$defs": {
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "tabBadgeState": {
      "type": "string",
      "enum": ["running", "awaiting-approval", "completed", "error"]
    },
    "toolCallStatus": {
      "type": "string",
      "enum": ["started", "completed", "awaiting-approval", "error"]
    },
    "tabBadgeEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "state", "sessionId", "adapterName", "workspaceId", "timestamp"],
      "properties": {
        "type": {
          "const": "harness/tab-badge"
        },
        "state": {
          "$ref": "#/$defs/tabBadgeState"
        },
        "sessionId": {
          "type": "string",
          "minLength": 1
        },
        "adapterName": {
          "type": "string",
          "minLength": 1
        },
        "workspaceId": {
          "$ref": "#/$defs/workspaceId"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "toolCallEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "status", "toolName", "sessionId", "adapterName", "workspaceId", "timestamp"],
      "properties": {
        "type": {
          "const": "harness/tool-call"
        },
        "status": {
          "$ref": "#/$defs/toolCallStatus"
        },
        "toolName": {
          "type": "string",
          "minLength": 1
        },
        "sessionId": {
          "type": "string",
          "minLength": 1
        },
        "adapterName": {
          "type": "string",
          "minLength": 1
        },
        "workspaceId": {
          "$ref": "#/$defs/workspaceId"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "toolCallId": {
          "type": "string",
          "minLength": 1
        },
        "inputSummary": {
          "type": "string",
          "minLength": 1
        },
        "resultSummary": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sessionHistoryEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "sessionId", "adapterName", "workspaceId", "timestamp", "transcriptPath"],
      "properties": {
        "type": {
          "const": "harness/session-history"
        },
        "sessionId": {
          "type": "string",
          "minLength": 1
        },
        "adapterName": {
          "type": "string",
          "minLength": 1
        },
        "workspaceId": {
          "$ref": "#/$defs/workspaceId"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "transcriptPath": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
