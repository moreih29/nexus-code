{
  "name": "@nexus/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "imports": {
    "#shared/*": "./node_modules/@nexus/shared/dist/*"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.scripts.json",
    "compile": "bun run scripts/compile-sidecar.ts",
    "dev": "bun src/index.ts",
    "dev:watch": "bun --watch src/index.ts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@nexus/shared": "workspace:*",
    "hono": "^4.12.11",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "better-sqlite3": "^12.8.0",
    "eslint": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "*",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.2"
  }
}
