{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus Code",
  "version": "0.0.0",
  "identifier": "com.nexus.code",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist",
    "beforeDevCommand": "bun run --filter @nexus/web dev",
    "beforeBuildCommand": "bun run --filter @nexus/web build"
  },
  "app": {
    "windows": [
      {
        "title": "Nexus Code",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/nexus-sidecar"]
  }
}
