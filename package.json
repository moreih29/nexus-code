{
  "name": "nexus-code",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "gen:contracts": "bun ./scripts/gen-contracts.ts",
    "test": "bun test ./packages/shared/src ./packages/app/src ./packages/app/scripts/packaging ./packages/app/test",
    "typecheck": "bun run --cwd packages/shared typecheck && bun run --cwd packages/app typecheck",
    "build": "bun run --cwd packages/app build",
    "check:dist-require": "bash ./scripts/check-dist-require.sh",
    "check:dist": "bun run check:dist-require",
    "test:sidecar": "cd sidecar && go test ./...",
    "test:go": "cd sidecar && go test ./...",
    "test:drift": "bash scripts/check-go-contracts-drift.sh",
    "test:diff-check": "git diff --check",
    "lint": "bun run --cwd packages/app lint:renderer"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ajv": "^8.20.0",
    "ajv-formats": "3.x",
    "bun-types": "^1.3.13",
    "json-schema-to-typescript": "15.0.4",
    "typescript": "6.0.3"
  }
}
