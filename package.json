{
  "name": "nexus-code",
  "version": "0.1.0",
  "description": "VSCode-style editor + workspace tool for macOS. Monaco + LSP + PTY. Dev only.",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.shared.json && tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.preload.json && tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.utility.json",
    "lint": "eslint src --ext ts,tsx",
    "clean": "rm -rf out dist",
    "postinstall": "electron-rebuild -f -w node-pty,better-sqlite3",
    "test:unit": "bun test tests/unit/",
    "test:integration": "bun test tests/integration/"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "monaco-languageclient": "^10.7.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript-language-server": "^5.1.3",
    "vscode-languageserver-protocol": "^3.17.5",
    "zod": "^3.25.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
